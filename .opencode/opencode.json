{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [".opencode/rules/*.md"],
  "permission":
    { 
        "graphify*": "allow",
        "mempalace*": "deny"
    },
  "agent": {
    "general": {
      "model": "minimax-coding-plan/MiniMax-M2.5",
      "permission": {
        "*": "allow"
      }
    },
    "explore": {
      "model": "minimax-coding-plan/MiniMax-M2.5"
    },
    "code-executor": {
      "description": "Основной исполнитель кода в экосистеме OpenCode. Пишет код, выполняет задачи, работает с файлами и репозиторием напрямую.",
      "mode": "subagent",
      "model": "minimax-coding-plan/MiniMax-M2.5",
      "prompt": "{file:agents/code-executor.md}",
      "temperature": 0.7,
      "permission": {
        "todowrite": "allow",
        "bash": {
          "npm run *": "allow",
          "npx vitest *": "allow",
          "npx *": "allow",
          "ls *": "allow",
          "git *": "allow",
          "gh *": "allow",
          "cat *": "allow",
          "rm *": "deny",
          "*": "deny"
        },
        "edit": "allow",
        "task": {
          "*": "deny",
          "general": "allow"
        }
      }
    },
    "architect": {
      "description": "Системный архитектор. Проектирует архитектуру, анализирует tradeoffs, предлагает паттерны и решения.",
      "mode": "subagent",
      "model": "zai-coding-plan/glm-4.7",
      "prompt": "{file:agents/architect.md}",
      "temperature": 0.4,
      "permission": {
        "todowrite": "allow",
        "bash": {
          "grep *": "allow",
          "find *": "allow",
          "ls *": "allow",
          "*": "deny"
        },
        "edit": "ask",
        "task": "deny"
      }
    },
    "security-reviewer": {
      "description": "Агент по безопасности. Проводит security audit, анализ уязвимостей, проверки прав доступа.",
      "mode": "subagent",
      "model": "zai-coding-plan/glm-4.7",
      "prompt": "{file:agents/security-reviewer.md}",
      "temperature": 0.6,
      "permission": {
        "todowrite": "allow",
        "task": "deny",
        "bash": {
          "npm audit *": "allow",
          "npx *": "allow",
          "grep *": "allow",
          "*": "deny"
        },
        "edit": "deny",
        "webfetch": "ask"
      }
    },
    "documentation-agent": {
      "description": "Документационный агент. Пишет документацию, README, API docs, генерирует changelog.",
      "mode": "subagent",
      "model": "minimax-coding-plan/MiniMax-M2.5",
      "prompt": "{file:agents/documentation-agent.md}",
      "temperature": 0.7,
      "permission": {
        "todowrite": "allow",
        "bash": {
          "grep *": "allow",
          "ls *": "allow",
          "npx typedoc *": "allow",
          "*": "deny"
        },
        "edit": "allow",
        "task": {
          "*": "deny",
          "general": "allow"
        }
      }
    },
    "qa-engineer": {
      "description": "QA-инженер. Проектирует test strategy, пишет test cases, анализирует bug reports.",
      "mode": "subagent",
      "model": "minimax-coding-plan/MiniMax-M2.5",
      "prompt": "{file:agents/qa-engineer.md}",
      "temperature": 0.4,
      "permission": {
        "todowrite": "allow",
        "bash": {
          "grep *": "allow",
          "npx vitest --coverage *": "allow",
          "ls *": "allow",
          "*": "deny"
        },
        "edit": "ask",
        "task": {
          "*": "deny",
          "code-*": "allow"
        }
      }
    },
    "e2e-responder": {
      "description": "Тестовый агент для E2E-тестирования. Отвечает кратко, без инструментов.",
      "mode": "subagent",
      "model": "lemonade/extra.Qwen3.5-9B-GGUF",
      "prompt": "{file:agents/e2e-responder.md}",
      "temperature": 0.1,
      "permission": {
        "*": "deny"
      }
    }
  },
  "mcp": {
    "opencode-docs": {
      "type": "local",
      "enabled": true,
      "command": [
        "mcpdoc",
        "--urls",
        "OpenCode:/home/gna/workspase/projects/opencode-plugin-kafka/docs/opecode-llm.txt",
        "--follow-redirects",
        "--allowed-domains",
        "opencode.ai",
        "--transport",
        "stdio"
      ]
    },
    "mempalace": {
      "type": "local",
      "enabled": true,
      "command": [
        "mempalace-mcp"
      ]
    },
    "graphify": {
      "type": "local",
      "enabled": true,
      "command": [
        "uv",
        "run",
        "--with",
        "graphifyy[mcp]",
        "python",
        "-m",
        "graphify.serve",
        "/home/gna/workspase/projects/opencode-plugin-kafka/graphify-out/graph.json"
      ]
    }
  }
}
